{
  "trackers": {
    "primary": "github",
    "linear": {
      "enabled": false
    }
  },
  "notifications": {
    "telegram": {
      "enabled": true,
      "chatIdEnv": "TELEGRAM_CHAT_ID",
      "botTokenEnv": "TELEGRAM_BOT_TOKEN"
    },
    "slack": {
      "enabled": false
    }
  },
  "team": {
    "enabled": true,
    "members": [],
    "reviewAssignment": "round-robin"
  },
  "permissions": {
    "scope": "write"
  },
  "maxRetries": 3,
  "loopTimeoutMinutes": 30,
  "figma": {
    "enabled": false
  },
  "branch": {
    "pattern": "{tracker}-{issue-number}",
    "defaults": {
      "tracker": "issues"
    }
  }
}
