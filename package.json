{
  "name": "@elyun/bylane",
  "version": "1.12.0",
  "description": "Frontend development harness for Claude Code",
  "type": "module",
  "bin": {
    "bylane": "./src/cli.js",
    "bylane-monitor": "./src/monitor/index.js"
  },
  "scripts": {
    "monitor": "node src/monitor/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "release": "bash scripts/release.sh",
    "prepare": "git config core.hooksPath .githooks && chmod +x .githooks/pre-commit"
  },
  "dependencies": {
    "blessed": "^0.1.81",
    "chokidar": "^3.6.0"
  },
  "devDependencies": {
    "vitest": "^1.6.0"
  }
}
